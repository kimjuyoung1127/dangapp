{
  "name": "dangapp-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run check:encoding && npm run build --prefix frontend",
    "check:encoding:all": "node scripts/check-encoding.mjs --all",
    "start": "npm run start --prefix frontend",
    "lint": "npm run check:encoding && npm run lint --prefix frontend",
    "test": "npm run test --prefix frontend",
    "test:run": "npm run test:run --prefix frontend",
    "e2e": "npm run e2e --prefix frontend",
    "e2e:unauth": "npm run e2e:unauth --prefix frontend",
    "e2e:signed": "npm run e2e:signed --prefix frontend",
    "e2e:auth:record": "npm run e2e:auth:record --prefix frontend",
    "e2e:report": "npm run e2e:report --prefix frontend",
    "e2e:install": "npm run e2e:install --prefix frontend",
    "verify:local": "npm run check:encoding && npm run lint --prefix frontend && npm run test:run --prefix frontend && npm run build --prefix frontend",
    "check:encoding": "node scripts/check-encoding.mjs",
    "seed:debug": "node scripts/seed-chat-danglog-debug.mjs",
    "seed:cleanup": "node scripts/cleanup-chat-danglog-debug.mjs",
    "seed:check": "node scripts/check-chat-danglog-debug.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0"
  }
}
