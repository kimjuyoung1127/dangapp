{
  "name": "dangapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:encoding && next build",
    "check:encoding:all": "node ../scripts/check-encoding.mjs --all",
    "start": "next start",
    "lint": "npm run check:encoding && next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test --project chromium --grep-invert @manual",
    "e2e:unauth": "playwright test --project chromium --grep @unauth --grep-invert @manual",
    "e2e:signed": "playwright test --project chromium --grep @signed --grep-invert @manual",
    "e2e:auth:record": "playwright test --grep @manual --headed --project chrome",
    "e2e:report": "playwright show-report ../output/playwright/e2e/latest/html-report",
    "e2e:install": "playwright install chromium",
    "analyze": "ANALYZE=true next build",
    "check:encoding": "node ../scripts/check-encoding.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8.57.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^14.2.15",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "eslint-config-next": "^14.2.15",
    "jsdom": "^27.0.0",
    "vitest": "^3.2.4"
  }
}
